generator client {
  provider = "prisma-client-js"
}

// Prisma 7: the connection URL is no longer set here. It is resolved by
// `prisma.config.ts` (CLI/Migrate) and by the driver adapter passed to
// `PrismaClient` at runtime (see src/lib/db.ts).
datasource db {
  provider = "postgresql"
}

// Fase 0 catalog subset. See design D2 (sdd/fase-0-fundaciones/design):
// - cuid string IDs
// - material/size are free-form strings, not enums (small, evolving catalog)
// - price_cents is always an integer (never float) — see spec "Money and Date Invariants"
// - timestamps use timestamptz to make the UTC storage invariant explicit
// - slugs preserve the existing WooCommerce URLs (see design D4)
model Product {
  id          String   @id @default(cuid())
  slug        String   @unique
  name        String
  description String?
  // wooId: immutable WooCommerce Store API integer PK, set on every import.
  // Nullable to accommodate pre-import rows; provenance/future-diffing only
  // — `slug` remains the upsert key, never `wooId`.
  wooId       Int?     @unique

  categories Category[]
  variants   ProductVariant[]
  media      ProductMedia[]

  createdAt DateTime @default(now()) @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @db.Timestamptz(6)
}

model ProductVariant {
  id String @id @default(cuid())

  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  sku            String  @unique
  material       String?
  sizeMm         String?
  priceCents     Int
  // salePriceCents: promotional price in integer cents, set iff the source
  // product/variant is on_sale (see design D5). Null = not on sale.
  salePriceCents Int?
  // stock: on-hand quantity. No Fase-1 data source (the public WooCommerce
  // Store API exposes no quantities); the catalog import NEVER writes this
  // column. 0 = unknown/unmanaged quantity, NOT "zero available". Read
  // `inStock` for customer-facing availability — never infer it from `stock`.
  stock          Int     @default(0)
  // inStock: customer-facing availability sourced verbatim from the Store
  // API `is_in_stock` field. The ONLY authoritative availability signal —
  // the import ALWAYS sets this explicitly, never inferred from `stock`.
  inStock        Boolean @default(false)
  // wooId: immutable WooCommerce Store API integer PK (variation id, or the
  // product id for a synthesized simple-product variant). Nullable to
  // accommodate pre-import rows; provenance/future-diffing only — `sku`
  // remains the upsert key, never `wooId`.
  wooId          Int?    @unique

  createdAt DateTime @default(now()) @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @db.Timestamptz(6)
}

model Category {
  id   String @id @default(cuid())
  slug String @unique
  name String

  products Product[]

  createdAt DateTime @default(now()) @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @db.Timestamptz(6)
}

model ProductMedia {
  id String @id @default(cuid())

  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  url      String
  alt      String?
  position Int     @default(0)

  createdAt DateTime @default(now()) @db.Timestamptz(6)
}
