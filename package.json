{
  "name": "rodak",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=24.0.0 <25.0.0"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "db:check-drift": "prisma migrate diff --from-config-datasource --to-schema=prisma/schema.prisma --exit-code",
    "catalog:export": "tsx scripts/catalog/export.ts",
    "catalog:import": "tsx scripts/catalog/import.ts",
    "catalog:prune": "tsx scripts/catalog/prune.ts"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "7.8.0",
    "next": "16.2.10",
    "pg": "^8.22.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "server-only": "^0.0.1"
  },
  "devDependencies": {
    "@types/node": "26.1.1",
    "@types/pg": "^8.20.0",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "eslint": "9.39.5",
    "eslint-config-next": "16.2.10",
    "prisma": "7.8.0",
    "tsx": "^4.23.1",
    "typescript": "6.0.3",
    "vitest": "4.1.10"
  }
}
